<div class="lp-cover">
    {% if logo_path %}
    <img src="{{ logo_path }}" alt="Logo">
    {% endif %}
    {% if company_name %}
    <p class="company">{{ company_name }}</p>
    {% endif %}
    <h1>{{ project_name }}</h1>
    {% if subtitle %}
    <p class="subtitle">{{ subtitle }}</p>
    {% endif %}
    <div class="meta">
        {% if git_info %}
        <p>{{ git_info.format_version_string() }}</p>
        {% endif %}
        {% if author or author_email %}
        <p>{{ author }}{% if author and author_email %} &lt;{{ author_email }}&gt;{% elif author_email %}{{ author_email }}{% endif %}</p>
        {% endif %}
        <p>{{ date }}</p>
    </div>
</div>
